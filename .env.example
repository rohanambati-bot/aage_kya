# ─── Frontend (Vite) environment variables ───────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# Supabase project credentials (get from: Supabase dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API URL (deployed Express server)
# Local dev: leave blank — Vite proxy forwards /api/* to localhost:5000
# Production: set to your Railway or Render backend URL
# Example: VITE_API_URL=https://aage-kya-server.up.railway.app
VITE_API_URL=

# ─── NOTE ────────────────────────────────────────────────────────────────────
# The AI API key (Groq) is intentionally NOT listed here.
# It lives in server/.env as GROQ_API_KEY (server-side only, never exposed to the browser).
# See server/.env.example for the full list of server environment variables.